# --- Required (app won't start without these) ---
# PostgreSQL connection string from Supabase. Prefers the standard postgres://
# format; JDBC is also accepted.
DATABASE_URL=postgres://user:pass@host.supabase.co:5432/postgres?sslmode=require

# At least 32 bytes (64 hex chars) for HS256 JWT signing
JWT_SECRET=local-dev-only-secret-change-me-0123456789abcdef0123456789abcdef

# --- Optional (dev mode defaults degrade gracefully) ---
# Razorpay test/sandbox keys — without these payment endpoints use local
# placeholder order IDs
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret_here

# Brevo transactional email — without this emails are logged, not sent
BREVO_API_KEY=your_brevo_api_key_here

# Frontend origin for CORS (comma-separated allowed origins, * for any)
CORS_ALLOWED_ORIGINS=*

# DB pool size (Supabase free tier: keep small)
DB_POOL_SIZE=5
